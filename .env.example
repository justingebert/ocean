# =====================================================================
# Backend runtime (Play + Slick + Mongo + LDAP)
# =====================================================================

# ≥32 chars (Play HS256).
APPLICATION_SECRET=dev-application-secret-change-me-32chars-minimum
JWT_SECRET=dev-jwt-secret-change-me-32chars-minimum

# Allowed hosts filter
HOST_IP=localhost

# Internal ORM database (postgres_orm)
SLICK_DB_URL=jdbc:postgresql://postgres_orm:5432/internal
SLICK_DB_USER=postgres
SLICK_DB_PASSWORD=postgres

# Managed Postgres cluster (pg_cluster)
PG_CLUSTER_HOSTNAME=pg_cluster
PG_CLUSTER_PORT=5432
PG_CLUSTER_DATABASE=internal
PG_CLUSTER_USER=postgres
PG_CLUSTER_PASSWORD=postgres

# Managed MongoDB cluster (mongodb_cluster)
MONGODB_CLUSTER_HOSTNAME=mongodb_cluster
MONGODB_CLUSTER_PORT=27017
MONGODB_CLUSTER_DATABASE=admin
MONGODB_CLUSTER_USER=root
MONGODB_CLUSTER_PASSWORD=toor

# LDAP
LDAP_HOST=openldap
LDAP_PORT=1389
LDAP_START_TLS=false
LDAP_USE_SSL=false
LDAP_NAME=cn=%USER%,%USER_ROOT%
LDAP_USER_ROOT=ou=users,dc=example,dc=org

# =====================================================================
# Frontend
# =====================================================================

# Connection-info shown to end users in the dashboard.
VITE_POSTGRESQL_HOSTNAME=localhost
VITE_POSTGRESQL_PORT=5555
VITE_MONGODB_HOSTNAME=localhost
VITE_MONGODB_PORT=27017
VITE_ADMINER_URL=http://localhost:8080/
VITE_ISSUE_LINK=https://github.com/HTWHub/ocean/issues

# Empty (default) uses relative `/v1`, proxied by Vite dev / Caddy prod.
# Set only for split-origin deploys (SPA + API on different hosts).
VITE_API_URL=