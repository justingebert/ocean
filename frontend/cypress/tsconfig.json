{
  "compilerOptions": {
    "rootDir": "..",
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["cypress", "node", "vite/client"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true
  },
  "include": [
    "e2e/**/*.ts",
    "e2e/**/*.tsx",
    "support/**/*.ts",
    "support/**/*.tsx",
    "../src/**/*.cy.ts",
    "../src/**/*.cy.tsx"
  ]
}
