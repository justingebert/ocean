# /etc/ocean/backend.env
# Backend runtime config + secrets. Fill real values and chmod 600.

APPLICATION_SECRET=change-me-application-secret-32chars-minimum
JWT_SECRET=change-me-jwt-secret-32chars-minimum
HOST_IP=ocean-jg.f4.htw-berlin.de

# Internal ORM database, local to this Docker Compose project.
SLICK_DB_URL=jdbc:postgresql://postgres_orm:5432/internal
SLICK_DB_USER=postgres
SLICK_DB_PASSWORD=change-me

# Managed database systems, also local in single-VM mode.
PG_CLUSTER_HOSTNAME=pg_cluster
PG_CLUSTER_PORT=5432
PG_CLUSTER_DATABASE=internal
PG_CLUSTER_USER=postgres
PG_CLUSTER_PASSWORD=change-me

MONGODB_CLUSTER_HOSTNAME=mongodb_cluster
MONGODB_CLUSTER_PORT=27017
MONGODB_CLUSTER_DATABASE=admin
MONGODB_CLUSTER_USER=root
MONGODB_CLUSTER_PASSWORD=change-me

LDAP_HOST=openldap
LDAP_PORT=1389
LDAP_START_TLS=false
LDAP_USE_SSL=false
LDAP_NAME=cn=%USER%,%USER_ROOT%
LDAP_USER_ROOT=ou=users,dc=example,dc=org
